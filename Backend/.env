# Application
APP_ENV=development
APP_NAME=flowforge-api
APP_PORT=8080
CORS_ALLOWED_ORIGINS=*

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=iqbal
POSTGRES_PASSWORD=130908
POSTGRES_NAME=flowforge
POSTGRES_SSLMODE=disable
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_CONN_MAX_LIFETIME=1h

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-key-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Rate Limiting
RATE_LIMIT_AUTHENTICATED=100
RATE_LIMIT_ANONYMOUS=20

# AI Integration optional
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=

# Observability
SENTRY_DSN=
LOG_LEVEL=info
PASSWORD_ENCRYPTION_PRIVATE_KEY_
